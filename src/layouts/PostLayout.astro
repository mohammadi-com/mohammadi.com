---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatPostDate, getReadingMinutes, type BlogPost } from "@/utils/posts";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const { title, description, pubDatetime, modDatetime, tags } = post.data;
---

<BaseLayout title={title} description={description} type="article">
  <article class="article section narrow">
    <header class="article-header">
      <p class="post-meta">
        <time datetime={pubDatetime.toISOString()}>{formatPostDate(pubDatetime)}</time>
        <span>{getReadingMinutes(post.body)} min read</span>
        {modDatetime && <span>Updated {formatPostDate(modDatetime)}</span>}
      </p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <ul class="inline-tags" aria-label={`${title} tags`}>
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
