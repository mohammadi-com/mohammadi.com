---
import config from "@/config";

type Props = {
  buttonLabel?: string;
  compact?: boolean;
  description?: string;
  featured?: boolean;
  note?: string;
  title?: string;
};

const {
  buttonLabel = "Subscribe",
  compact = false,
  description = "New posts, occasionally.",
  featured = false,
  note,
  title = "Newsletter",
} = Astro.props;
const { newsletter } = config;

const action =
  newsletter && newsletter.provider === "buttondown"
    ? `https://buttondown.com/api/emails/embed-subscribe/${newsletter.username}`
    : undefined;
---

{
  action && (
    <section
      class:list={[
        "not-prose border-border",
        featured
          ? "bg-muted/40 my-8 rounded-sm border p-5 sm:p-6"
          : "border-y border-dashed py-6",
        !featured && (compact ? "my-6" : "my-8"),
      ]}
    >
      <h2 class="text-lg font-semibold">{title}</h2>
      <p class="text-muted-foreground mt-2 text-sm">{description}</p>

      <form
        action={action}
        method="post"
        class="mt-4 flex flex-col gap-3 sm:flex-row"
      >
        <label for="newsletter-email" class="sr-only">
          Email address
        </label>
        <input
          id="newsletter-email"
          type="email"
          name="email"
          autocomplete="email"
          required
          placeholder="you@example.com"
          class="border-border bg-background text-foreground placeholder:text-muted-foreground min-h-11 flex-1 rounded-sm border px-3 py-2 text-sm"
        />
        <button
          type="submit"
          class="bg-accent text-background hover:bg-accent/90 min-h-11 rounded-sm px-4 py-2 text-sm font-medium"
        >
          {buttonLabel}
        </button>
      </form>

      {note && <p class="text-muted-foreground mt-3 text-xs">{note}</p>}
    </section>
  )
}
