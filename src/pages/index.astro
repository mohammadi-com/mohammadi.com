---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import NewsletterForm from "@/components/NewsletterForm.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout description={config.site.description}>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-6 pb-4">
      <div class="flex flex-col items-start gap-4 sm:flex-row">
        <a
          href={getRelativeLocaleUrl(locale, "about")}
          class="group mx-auto block sm:mx-0"
        >
          <img
            src={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}mohammad-avatar.png`}
            alt="Mohammad Mohammadi"
            class="size-40 shrink-0 rounded-full object-cover transition-all duration-300 group-hover:scale-105 group-hover:shadow-xl"
          />
        </a>
        <div class="flex-1 text-center sm:text-left">
          <div class="flex items-center justify-center gap-2 sm:justify-start">
            <h1
              class="my-2 inline-block text-2xl font-bold sm:my-4 sm:text-3xl"
            >
              Hi, I&apos;m @mohammadi-com.
            </h1>
            <a
              target="_blank"
              href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
              class="inline-block"
              aria-label="RSS Feed"
              title="RSS Feed"
            >
              <IconRss
                width={20}
                height={20}
                class="stroke-accent scale-125 stroke-3 rtl:-rotate-90"
              />
              <span class="sr-only">RSS Feed</span>
            </a>
          </div>
          <p>
            Practical software, backend systems, automation, and open-source
            notes.
          </p>
          <p class="mt-2">
            This is my weblog and home base on the web. Longer-running context
            lives on the
            <LinkButton
              class="hover:text-accent underline decoration-dashed underline-offset-4"
              href={getRelativeLocaleUrl(locale, "about")}
            >
              about page
            </LinkButton>.
          </p>
          {
            socials.length > 0 && (
              <div class="mt-4 flex flex-row items-center justify-center sm:justify-start">
                <Socials />
              </div>
            )
          }
        </div>
      </div>
    </section>

    <NewsletterForm
      featured
      title="Working notes"
      description="Backend systems, automation, AI, and the parts that survive production."
      note="Short. Practical. Sent only when there is something worth keeping."
      buttonLabel="Subscribe"
    />

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.featured}
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <ul>
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
