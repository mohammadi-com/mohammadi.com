---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { profile } from "@/data/profile";
---

<BaseLayout title="Notes" description={`Notes and writing by ${profile.name}.`}>
  <section class="page-hero section narrow">
    <p class="eyebrow">Notes</p>
    <h1>Short writing from the workbench.</h1>
    <p class="lede">
      A place for engineering notes, project updates, and lessons that are worth keeping outside a social feed.
    </p>
  </section>

  <section class="section note-list narrow" aria-label="Notes">
    {profile.notes.map((note) => (
      <article class="note-item">
        <div>
          <p class="note-meta">{note.date} / {note.minutes} min read</p>
          <h2><a href={note.href}>{note.title}</a></h2>
          <p>{note.description}</p>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
