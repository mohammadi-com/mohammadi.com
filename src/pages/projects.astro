---
import ProjectCard from "@/components/ProjectCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { profile } from "@/data/profile";
---

<BaseLayout title="Projects" description={`Selected projects and public work by ${profile.name}.`}>
  <section class="page-hero section narrow">
    <p class="eyebrow">Projects</p>
    <h1>Open work, job-search tools, and backend practice.</h1>
    <p class="lede">
      A small selection from the public GitHub trail. The theme is consistent: tools that help people move through practical workflows faster.
    </p>
  </section>

  <section class="section">
    <div class="project-grid">
      {profile.projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
